{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",          // ⬅️ Changed from CommonJS
    "moduleResolution": "NodeNext", // ⬅️ Added for ESM support
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": ["src/**/*"]
}