{
  "name": "swigitt",
  "version": "1.0.12",
  "type": "module",
  "description": "AI-powered Git CLI with CleanPR protection: automate commits, prevent leaks, and ship code in one command.",
  "main": "dist/index.js",
  "bin": {
    "swigit": "dist/index.js",
    "sg": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "git",
    "cli",
    "ai",
    "gemini",
    "automation",
    "workflow",
    "security",
    "commit"
  ],
  "author": "Charvi Wadhwa",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/charrviwadhwa/swigit.git"
  },
  "bugs": {
    "url": "https://github.com/charrviwadhwa/swigit/issues"
  },
  "homepage": "https://swigit-website.vercel.app/",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "prepack": "npm run build",
    "start": "node ./dist/index.js"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "simple-git": "^3.33.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3"
  }
}
